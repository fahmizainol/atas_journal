DATABENTO_API_KEY=YOUR_KEY_HERE

# AI analyzer — LiteLLM model strings. LLM_MODEL is the default; LLM_MODELS is a
# comma-separated list of models you can pick between to compare reviews
# (Claude vs ChatGPT vs DeepSeek, etc.). Set each provider's API key below;
# LiteLLM reads them from the environment.
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-4o,deepseek/deepseek-chat
# ANTHROPIC_API_KEY=YOUR_KEY_HERE
# OPENAI_API_KEY=YOUR_KEY_HERE
# DEEPSEEK_API_KEY=YOUR_KEY_HERE
